# Copy to .env (gitignored) and fill in. Generate the Fernet key with:
#   python manage.py generate_key
POS_FERNET_KEY=

# Credentials for the dev grosir connection (seeded by `python manage.py seed_dev`).
POS_DB_GROSIR_HOST=localhost
POS_DB_GROSIR_PORT=1433
POS_DB_GROSIR_NAME=database
POS_DB_GROSIR_USER=sa
POS_DB_GROSIR_PASSWORD=

# Set to 1 in production to enforce Tailscale-only access on /admin-panel/*.
ENFORCE_TAILSCALE=0
