# Copy to .env (gitignored) and fill in.
# On Windows: JANGAN pakai `Set-Content -Encoding utf8` (bikin BOM + mojibake).
# Edit manual atau append UTF-8 tanpa BOM.

# === Enkripsi ===============================================================
# Kunci Fernet untuk enkripsi password koneksi MS SQL. Generate:
#   python manage.py generate_key
POS_FERNET_KEY=

# === Koneksi grosir dev (di-seed oleh `python manage.py seed_dev`) ==========
POS_DB_GROSIR_HOST=localhost
POS_DB_GROSIR_PORT=1433
POS_DB_GROSIR_NAME=database
POS_DB_GROSIR_USER=sa
POS_DB_GROSIR_PASSWORD=

# === Django core ============================================================
# 1 = dev (Vite HMR, error verbose). 0 = produksi. Default: 1.
DEBUG=1
# WAJIB di-set di produksi (DEBUG=0). Generate:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=
# Host/domain yang boleh mengakses. Comma-separated. Prefix "." = wildcard subdomain.
# Contoh: LAN + Tailscale → 127.0.0.1,localhost,192.168.1.10,namamesin.namatailnet.ts.net
ALLOWED_HOSTS=127.0.0.1,localhost
# Idle session (detik). Default 14400 (4 jam).
SESSION_IDLE_SECONDS=14400

# === Akses jaringan (/admin-panel/*) =======================================
# 1 = batasi admin panel ke range Tailscale saja. Default: ikut (not DEBUG).
ENFORCE_TAILSCALE=0
# Range CGNAT Tailscale. Ubah hanya bila tailnet custom. Default 100.64.0.0/10.
TAILSCALE_CIDR=100.64.0.0/10

# === Vite / static ==========================================================
# 1 = mode HMR (butuh `npm run dev`, akses localhost saja).
# 0 = serve hasil `npm run build` dari Django (bisa lintas device/Tailscale).
# Kosong = ikut DEBUG.
DJANGO_VITE_DEV=0

# === Database indexes =======================================================
# Auto-index MSSQL saat profil aktif/terdaftar (1=aktif, 0=manual via manage.py ensure_indexes)
POS_AUTO_INDEX=1

# === Snapshot harga harian (scheduler in-process) ===========================
# Deteksi perubahan harga per hari untuk koneksi aktif, jalan sendiri selama
# server hidup (tanpa Task Scheduler). 0 = matikan (pakai `manage.py snapshot_harga` manual).
HARGA_SNAPSHOT_ENABLED=1
# Jam lokal minimum sebelum boleh jalan (0 = kesempatan pertama tiap hari saat server hidup).
HARGA_SNAPSHOT_HOUR=0
# Jeda cek antar-iterasi (detik). Default 1800 = 30 menit. Dipakai bersama snapshot stok.
HARGA_SNAPSHOT_INTERVAL_SECONDS=1800

# === Snapshot stok (scheduler in-process, SEMUA profil) =====================
# Dua lapis: base beku (~13 bln lalu, rebuild bulanan) + live (base + delta,
# rebuild harian). Halaman Stok Akhir dkk baca live + delta kecil → detik-an.
# Jalan untuk SEMUA server, berurutan, per-profil terisolasi.
# 0 = matikan (pakai `manage.py snapshot_stok` manual / Task Scheduler).
STOK_SNAPSHOT_ENABLED=1
# Jam lokal minimum sebelum boleh jalan. Default 0 = kesempatan pertama tiap hari
# SAAT SERVER HIDUP (server toko cuma nyala jam kerja, bukan dini hari). Tick
# scheduler tiap 30 mnt retry sampai sukses hari itu.
STOK_SNAPSHOT_HOUR=0
# Batas region immutable (bulan). Rebuild live cukup scan window ini, bukan
# seluruh histori sejak tutup buku. Default 13 (admin diasumsikan tak edit data
# lebih lama dari ini).
STOK_SNAPSHOT_BASE_MONTHS=13
# Umur maksimum snapshot live (hari) sebelum dianggap basi → jalur baca fallback
# ke re-agregasi penuh. Default 7.
STOK_SNAPSHOT_MAX_AGE_DAYS=7

# === Laporan: batas & fleksibilitas akses data ==============================
# Tabel di layar tetap paginated (ringan). Export = XLSX STREAMING (cursor ->
# openpyxl write_only, memori app datar walau ratusan ribu baris) + rentang
# tanggal dilepas. Peringan DB berat = set report_source (replica) pada profil
# koneksi. Semua batas opsional (punya default), bisa ditune tanpa ubah kode.
# Plafon page-size tabel layar (opsi UI s.d. 1000). Default 1000.
REPORT_MAX_PER_PAGE=1000
# Clamp rentang tanggal jalur INTERAKTIF (hari); jalur export TIDAK di-clamp. Default 92.
REPORT_MAX_RANGE_DAYS=92
# Batas baris export XLSX (jaga limit Excel ~1jt baris). Default 100000.
REPORT_EXPORT_CAP=100000
