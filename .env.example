# Copy to .env (gitignored) and fill in.
# On Windows: JANGAN pakai `Set-Content -Encoding utf8` (bikin BOM + mojibake).
# Edit manual atau append UTF-8 tanpa BOM.

# === Enkripsi ===============================================================
# Kunci Fernet untuk enkripsi password koneksi MS SQL. Generate:
#   python manage.py generate_key
POS_FERNET_KEY=

# === Koneksi grosir dev (di-seed oleh `python manage.py seed_dev`) ==========
POS_DB_GROSIR_HOST=localhost
POS_DB_GROSIR_PORT=1433
POS_DB_GROSIR_NAME=database
POS_DB_GROSIR_USER=sa
POS_DB_GROSIR_PASSWORD=

# === Django core ============================================================
# 1 = dev (Vite HMR, error verbose). 0 = produksi. Default: 1.
DEBUG=1
# WAJIB di-set di produksi (DEBUG=0). Generate:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=
# Host/domain yang boleh mengakses. Comma-separated. Prefix "." = wildcard subdomain.
# Contoh: LAN + Tailscale → 127.0.0.1,localhost,192.168.1.10,namamesin.namatailnet.ts.net
ALLOWED_HOSTS=127.0.0.1,localhost
# Idle session (detik). Default 14400 (4 jam).
SESSION_IDLE_SECONDS=14400

# === Akses jaringan (/admin-panel/*) =======================================
# 1 = batasi admin panel ke range Tailscale saja. Default: ikut (not DEBUG).
ENFORCE_TAILSCALE=0
# Range CGNAT Tailscale. Ubah hanya bila tailnet custom. Default 100.64.0.0/10.
TAILSCALE_CIDR=100.64.0.0/10

# === Vite / static ==========================================================
# 1 = mode HMR (butuh `npm run dev`, akses localhost saja).
# 0 = serve hasil `npm run build` dari Django (bisa lintas device/Tailscale).
# Kosong = ikut DEBUG.
DJANGO_VITE_DEV=0
